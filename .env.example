## Base
APP_BASE_URL=http://localhost:3000
NODE_ENV=development

## Admin (bcrypt hash of your chosen password)
ADMIN_PASSWORD_HASH=

## Database
DATABASE_URL=postgresql://demokrati:demokrati@localhost:5432/demokrati

## Redis
REDIS_URL=redis://localhost:6379

## Storage (local disk in dev, can be s3-compatible in prod)
STORAGE_DIR=./data/storage

## Model providers — set any combination you want available
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

## Model profiles — map to { provider, name }
MODEL_FAST_PROVIDER=anthropic
MODEL_FAST_NAME=claude-haiku-4-5-20251001
MODEL_STRONG_PROVIDER=anthropic
MODEL_STRONG_NAME=claude-sonnet-4-6
MODEL_MULTILINGUAL_PROVIDER=anthropic
MODEL_MULTILINGUAL_NAME=claude-sonnet-4-6
MODEL_EMBED_PROVIDER=openai
MODEL_EMBED_NAME=text-embedding-3-large
MODEL_SAFE_PROVIDER=anthropic
MODEL_SAFE_NAME=claude-sonnet-4-6

## hCaptcha (https://www.hcaptcha.com)
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

## Rate limits
RATE_LIMIT_PUBLIC_RUNS_PER_HOUR=20
RATE_LIMIT_EXPENSIVE_RUNS_PER_DAY=5
FEATURED_CACHE_TTL_SECONDS=86400
LIVE_RUN_TIMEOUT_SECONDS=60

## Daily cost ceilings (USD)
DAILY_COST_CEILING_ANTHROPIC=20
DAILY_COST_CEILING_OPENAI=20
DAILY_COST_CEILING_GOOGLE=20

## Observability (optional)
SENTRY_DSN=
PLAUSIBLE_DOMAIN=
